# PostgreSQL connection string
# Neon (recommended): https://neon.tech
# Local:              postgresql://user:password@localhost:5432/tamouri
DATABASE_URL="postgresql://user:password@host:5432/tamouri?sslmode=require"

# Auth.js (NextAuth) — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-32-byte-random-base64-string"

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Resend — https://resend.com/api-keys (optional: omit to skip order emails)
RESEND_API_KEY="re_..."

# Public base URL — used for sitemaps, canonical URLs, and JSON-LD
# Production example: https://tamouri.onrender.com
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Upstash Redis — rate limiting (login, register, checkout, coupon validation)
# Required on Vercel (serverless). Without these the app falls back to in-memory
# rate limiting, which resets on every cold start.
# Create a free Redis database at: https://console.upstash.com
UPSTASH_REDIS_REST_URL="https://your-db.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-token-here"

# WhatsApp order notifications via CallMeBot (optional — omit to disable)
# Setup: https://www.callmebot.com/blog/free-api-whatsapp-messages/
#   1. Send "I allow callmebot.com to send me messages" to +34 644 59 62 64 on WhatsApp
#   2. Wait for the reply with your personal APIKEY
#   3. Set the two vars below in Vercel → Settings → Environment Variables
WHATSAPP_PHONE="971501234567"   # international format, no +
WHATSAPP_APIKEY="your-callmebot-apikey"
