# PostgreSQL connection string
# Neon (recommended): https://neon.tech
# Local:              postgresql://user:password@localhost:5432/tamouri
DATABASE_URL="postgresql://user:password@host:5432/tamouri?sslmode=require"

# Auth.js (NextAuth) — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-32-byte-random-base64-string"
