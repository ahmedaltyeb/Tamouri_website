# PostgreSQL connection string
# Neon (recommended): https://neon.tech
# Local:              postgresql://user:password@localhost:5432/tamouri
DATABASE_URL="postgresql://user:password@host:5432/tamouri?sslmode=require"

# Auth.js (NextAuth) — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-32-byte-random-base64-string"

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Resend — https://resend.com/api-keys (optional: omit to skip order emails)
RESEND_API_KEY="re_..."

# Public base URL — used for sitemaps, canonical URLs, and JSON-LD
# Production example: https://tamouri.onrender.com
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
