generator client {
  provider = "prisma-client-js"
}

// Prisma 7: url is no longer in the schema file.
// Runtime connection → lib/prisma.ts (PrismaPg adapter).
// Migrate connection → prisma.config.ts.
datasource db {
  provider = "postgresql"
}

// ─── Categories ──────────────────────────────────────────────────────────────

model Category {
  id            String    @id @default(cuid())
  name          String    @unique
  slug          String    @unique
  nameEn        String?
  nameAr        String?
  image         String?   // URL or /uploads path
  sortOrder     Int       @default(0)
  active        Boolean   @default(true)
  featured      Boolean   @default(false)
  url           String?
  totalProducts Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  products Product[]

  @@index([slug])
  @@index([active, sortOrder])
}

// ─── CMS: Testimonials ───────────────────────────────────────────────────────

model Testimonial {
  id         String   @id @default(cuid())
  nameEn     String
  nameAr     String
  locationEn String?
  locationAr String?
  reviewEn   String
  reviewAr   String
  productEn  String?
  productAr  String?
  rating     Int      @default(5)
  avatar     String?  // initials or image URL
  color      String   @default("bg-amber-100 text-amber-700")
  active     Boolean  @default(true)
  featured   Boolean  @default(false)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([active, sortOrder])
}

// ─── CMS: Feature Cards (Why Us section) ─────────────────────────────────────

model FeatureCard {
  id            String   @id @default(cuid())
  icon          String   @default("box")
  titleEn       String
  titleAr       String
  descriptionEn String
  descriptionAr String
  color         String   @default("bg-blue-50 text-blue-600 border-blue-100")
  active        Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([active, sortOrder])
}

// ─── CMS: Homepage Section Headers ───────────────────────────────────────────

model HomepageSection {
  id         String   @id @default(cuid())
  key        String   @unique
  badgeEn    String?
  badgeAr    String?
  titleEn    String?
  titleAr    String?
  subtitleEn String?
  subtitleAr String?
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([key])
}

// ─── CMS: Static Pages ───────────────────────────────────────────────────────

model Page {
  id        String   @id @default(cuid())
  slug      String   @unique
  titleEn   String
  titleAr   String
  contentEn String   @db.Text
  contentAr String   @db.Text
  seoTitleEn    String?
  seoTitleAr    String?
  seoDescEn      String?
  seoDescAr      String?
  heroImage      String?
  heroImageAltEn String?
  heroImageAltAr String?
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug, published])
}

// ─── Store Settings ───────────────────────────────────────────────────────────

model StoreSettings {
  id           String   @id @default(cuid())
  name         String
  nameEn       String?
  nameAr       String?
  taglineEn    String?
  taglineAr    String?
  logo         String?
  favicon      String?
  description  String?
  location     String?
  addressEn    String?
  addressAr    String?
  phone        String?
  whatsapp     String?
  email        String?
  workingHours String?
  currency     String   @default("AED")
  websiteUrl   String?
  instagramUrl String?
  twitterUrl   String?
  whatsappUrl  String?
  seoTitleEn   String?
  seoTitleAr   String?
  seoDescEn    String?
  seoDescAr    String?
  ogImage      String?
  themeJson    String?  // JSON: { primary, secondary, accent, success, background, text }
  updatedAt    DateTime @updatedAt
}

// ─── CMS: Hero Slides ─────────────────────────────────────────────────────────

model HeroSlide {
  id         String   @id @default(cuid())
  order      Int      @default(0)
  image      String
  titleEn    String?
  titleAr    String?
  subtitleEn String?
  subtitleAr String?
  ctaLabelEn String?
  ctaLabelAr String?
  ctaUrl     String?
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([active, order])
}

// ─── CMS: Sections (unified headless CMS engine) ─────────────────────────────
//
// Each "section" represents one piece of CMS content.
// type values: hero | products | footer | payment_methods | banner | custom
// data is a JSON string — schema varies per type.

model CmsSection {
  id        String   @id @default(cuid())
  type      String   // hero | products | footer | payment_methods | banner | custom
  title     String?  // human-readable label for admin UI
  data      String   // JSON blob — flexible per type
  enabled   Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, enabled])
  @@index([enabled, sortOrder])
}

// ─── Analytics Events ─────────────────────────────────────────────────────────

model AnalyticsEvent {
  id        String   @id @default(cuid())
  event     String   // page_view | product_view | add_to_cart | remove_from_cart | checkout_start | purchase_completed
  userId    String?
  sessionId String?
  productId String?
  metadata  String   @default("{}") // JSON blob
  createdAt DateTime @default(now())

  @@index([event, createdAt])
  @@index([productId, event])
  @@index([sessionId])
  @@index([createdAt])
}

// ─── CMS: Payment Methods ────────────────────────────────────────────────────

model PaymentMethod {
  id        String   @id @default(cuid())
  name      String
  image     String   // URL or /uploads path
  enabled   Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([enabled, sortOrder])
}

// ─── CMS: Footer Sections ─────────────────────────────────────────────────────

model FooterSection {
  id       String   @id @default(cuid())
  order    Int      @default(0)
  titleEn  String
  titleAr  String
  links    String   // JSON array: [{labelEn, labelAr, url}]
  active   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, order])
}

// ─── Products ────────────────────────────────────────────────────────────────

model Product {
  id            String    @id @default(cuid())
  sku           String?   @unique
  name          String    // JSON string: { en: string; ar: string } or legacy plain string
  description   String    // JSON string: { en: string; ar: string } or legacy plain string
  price         Float
  originalPrice Float?
  category      String
  categorySlug  String
  image         String            // primary image (legacy + always = images[0])
  images        String[]          // all product images in order
  badge         String?
  rating        Float     @default(0)
  reviews       Int       @default(0)
  inStock       Boolean   @default(true)
  stock         Int       @default(0)
  // Catalog import fields
  priceFrom     Float?
  priceTo       Float?
  currency      String    @default("AED")
  variants      String?
  productUrl    String?
  categoryId    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  categoryRef   Category?      @relation(fields: [categoryId], references: [id])
  orderItems    OrderItem[]
  wishlistItems WishlistItem[]
  cartItems     CartItem[]

  @@index([categorySlug])
  @@index([inStock])
  @@index([categoryId])
}

// ─── Users ───────────────────────────────────────────────────────────────────

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  name             String
  phone            String?
  passwordHash     String?   // null for guest users created by order checkout
  resetToken       String?   @unique
  resetTokenExpiry DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  orders    Order[]
  addresses Address[]
  wishlist  WishlistItem[]
  cartItems CartItem[]

  @@index([email])
}

model Address {
  id        String   @id @default(cuid())
  userId    String
  label     String   @default("Home")
  fullName  String
  phone     String
  line1     String
  line2     String?
  city      String
  emirate   String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
}

// ─── Orders ──────────────────────────────────────────────────────────────────

model Order {
  id              String      @id @default(cuid())
  userId          String
  status          OrderStatus @default(PENDING)
  total           Float
  shippingAddress String
  notes           String?
  stripeSessionId String?     @unique
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user          User                 @relation(fields: [userId], references: [id])
  items         OrderItem[]
  statusHistory OrderStatusHistory[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Float  // snapshot of product price at time of order

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

// ─── Admin Users ─────────────────────────────────────────────────────────────

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String
  role         AdminRole @default(ADMIN)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([email])
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum AdminRole {
  ADMIN
  SUPER_ADMIN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

// ─── Cart (persisted for logged-in users) ────────────────────────────────────

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
}

model OrderStatusHistory {
  id        String      @id @default(cuid())
  orderId   String
  status    OrderStatus
  note      String?
  createdAt DateTime    @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([createdAt])
}
