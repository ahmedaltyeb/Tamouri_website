generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Categories ──────────────────────────────────────────────────────────────

model Category {
  id            String    @id @default(cuid())
  name          String    @unique
  slug          String    @unique
  url           String?
  totalProducts Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  products Product[]

  @@index([slug])
}

// ─── Store Settings ───────────────────────────────────────────────────────────

model StoreSettings {
  id           String   @id @default(cuid())
  name         String
  nameEn       String?
  nameAr       String?
  taglineEn    String?
  taglineAr    String?
  logo         String?
  favicon      String?
  description  String?
  location     String?
  addressEn    String?
  addressAr    String?
  phone        String?
  whatsapp     String?
  email        String?
  workingHours String?
  currency     String   @default("AED")
  websiteUrl   String?
  instagramUrl String?
  twitterUrl   String?
  whatsappUrl  String?
  seoTitleEn   String?
  seoTitleAr   String?
  seoDescEn    String?
  seoDescAr    String?
  ogImage      String?
  updatedAt    DateTime @updatedAt
}

// ─── CMS: Hero Slides ─────────────────────────────────────────────────────────

model HeroSlide {
  id         String   @id @default(cuid())
  order      Int      @default(0)
  image      String
  titleEn    String?
  titleAr    String?
  subtitleEn String?
  subtitleAr String?
  ctaLabelEn String?
  ctaLabelAr String?
  ctaUrl     String?
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([active, order])
}

// ─── CMS: Footer Sections ─────────────────────────────────────────────────────

model FooterSection {
  id       String   @id @default(cuid())
  order    Int      @default(0)
  titleEn  String
  titleAr  String
  links    String   // JSON array: [{labelEn, labelAr, url}]
  active   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, order])
}

// ─── Products ────────────────────────────────────────────────────────────────

model Product {
  id            String    @id @default(cuid())
  sku           String?   @unique
  name          String    // JSON string: { en: string; ar: string } or legacy plain string
  description   String    // JSON string: { en: string; ar: string } or legacy plain string
  price         Float
  originalPrice Float?
  category      String
  categorySlug  String
  image         String            // primary image (legacy + always = images[0])
  images        String[]          // all product images in order
  badge         String?
  rating        Float     @default(0)
  reviews       Int       @default(0)
  inStock       Boolean   @default(true)
  stock         Int       @default(0)
  // Catalog import fields
  priceFrom     Float?
  priceTo       Float?
  currency      String    @default("AED")
  variants      String?
  productUrl    String?
  categoryId    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  categoryRef   Category?      @relation(fields: [categoryId], references: [id])
  orderItems    OrderItem[]
  wishlistItems WishlistItem[]
  cartItems     CartItem[]

  @@index([categorySlug])
  @@index([inStock])
  @@index([categoryId])
}

// ─── Users ───────────────────────────────────────────────────────────────────

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  name             String
  phone            String?
  passwordHash     String?   // null for guest users created by order checkout
  resetToken       String?   @unique
  resetTokenExpiry DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  orders    Order[]
  addresses Address[]
  wishlist  WishlistItem[]
  cartItems CartItem[]

  @@index([email])
}

model Address {
  id        String   @id @default(cuid())
  userId    String
  label     String   @default("Home")
  fullName  String
  phone     String
  line1     String
  line2     String?
  city      String
  emirate   String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
}

// ─── Orders ──────────────────────────────────────────────────────────────────

model Order {
  id              String      @id @default(cuid())
  userId          String
  status          OrderStatus @default(PENDING)
  total           Float
  shippingAddress String
  notes           String?
  stripeSessionId String?     @unique
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user          User                 @relation(fields: [userId], references: [id])
  items         OrderItem[]
  statusHistory OrderStatusHistory[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Float  // snapshot of product price at time of order

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

// ─── Admin Users ─────────────────────────────────────────────────────────────

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String
  role         AdminRole @default(ADMIN)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([email])
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum AdminRole {
  ADMIN
  SUPER_ADMIN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

// ─── Cart (persisted for logged-in users) ────────────────────────────────────

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
}

model OrderStatusHistory {
  id        String      @id @default(cuid())
  orderId   String
  status    OrderStatus
  note      String?
  createdAt DateTime    @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([createdAt])
}
